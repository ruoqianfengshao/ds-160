em\" bindtap=\"goToProducts\">\n        <text class=\"category-icon\">🔩</text>\n        <text class=\"category-text\">查看全部产品</text>\n      </view>\n    </view>\n  </view>\n\n  <!-- 快速联系 -->\n  <view class=\"card contact-card\">\n    <view class=\"section-title\">联系我们</view>\n    <view class=\"contact-info\">\n      <view class=\"contact-item\">\n        <text class=\"contact-icon\">📞</text>\n        <text class=\"contact-text\">{{phoneNumber}}</text>\n      </view>\n      <view class=\"contact-item\">\n        <text class=\"contact-icon\">📍</text>\n        <text class=\"contact-text\">{{address}}</text>\n      </view>\n    </view>\n    <button class=\"btn-primary\" bindtap=\"makePhoneCall\">立即拨打</button>\n  </view>\n</view>\n"}}],"api":"openai-completions","provider":"miaoda","model":"miaoda-model-auto","usage":{"input":37206,"output":752,"cacheRead":0,"cacheWrite":0,"totalTokens":37958,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774235994331}}
