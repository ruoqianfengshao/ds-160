;\n  color: #666;\n}\n\n.time-value {\n  font-size: 28rpx;\n  color: #333;\n  font-weight: 500;\n}\n\n.time-tip {\n  margin-top: 20rpx;\n  padding: 16rpx;\n  background: #fffbe6;\n  border-radius: 8rpx;\n  font-size: 24rpx;\n  color: #fa8c16;\n}\n\n.message-form {\n  display: flex;\n  flex-direction: column;\n  gap: 20rpx;\n}\n\n.form-item {\n  width: 100%;\n}\n\n.form-input {\n  width: 100%;\n  padding: 20rpx 24rpx;\n  background: #f5f5f5;\n  border-radius: 8rpx;\n  font-size: 28rpx;\n  box-sizing: border-box;\n}\n\n.form-textarea {\n  width: 100%;\n  padding: 20rpx 24rpx;\n  background: #f5f5f5;\n  border-radius: 8rpx;\n  font-size: 28rpx;\n  min-height: 200rpx;\n  box-sizing: border-box;\n}\n\n.btn-submit {\n  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);\n  color: #fff;\n  border: none;\n  border-radius: 8rpx;\n  padding: 24rpx;\n  font-size: 30rpx;\n  font-weight: 500;\n  margin-top: 10rpx;\n}\n\n.social-links {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 20rpx;\n}\n\n.social-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 30rpx 20rpx;\n  background: #f9f9f9;\n  border-radius: 12rpx;\n}\n\n.social-icon {\n  font-size: 48rpx;\n  margin-bottom: 16rpx;\n}\n\n.social-name {\n  font-size: 24rpx;\n  color: #666;\n  text-align: center;\n}\n"}}],"api":"openai-completions","provider":"miaoda","model":"miaoda-model-auto","usage":{"input":18606,"output":1282,"cacheRead":32186,"cacheWrite":0,"totalTokens":52074,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774494637454}}
