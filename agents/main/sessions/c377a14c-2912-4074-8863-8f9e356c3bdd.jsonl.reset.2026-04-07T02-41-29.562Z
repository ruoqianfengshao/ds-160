rder-radius: 20rpx;\n}\n\n.product-arrow {\n  font-size: 40rpx;\n  color: #ccc;\n  margin-left: 16rpx;\n}\n\n.advantage-list {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 20rpx;\n}\n\n.advantage-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 30rpx 20rpx;\n  background: #f9f9f9;\n  border-radius: 12rpx;\n  text-align: center;\n}\n\n.advantage-icon {\n  font-size: 56rpx;\n  margin-bottom: 16rpx;\n}\n\n.advantage-title {\n  font-size: 30rpx;\n  font-weight: 600;\n  color: #333;\n  margin-bottom: 8rpx;\n}\n\n.advantage-desc {\n  font-size: 24rpx;\n  color: #999;\n}\n"}],"isError":false,"timestamp":1774494637452}}
