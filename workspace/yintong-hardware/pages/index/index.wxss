/* pages/index/index.wxss - 首页样式 */
.banner {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.intro-card {
  text-align: center;
}

.intro-text {
  font-size: 28rpx;
  color: #666666;
  margin: 20rpx 0;
  line-height: 1.6;
}

.advantages {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 20rpx 0;
}

.advantage-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  margin: 10rpx;
}

.advantage-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.advantage-text {
  font-size: 24rpx;
  color: #666666;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 20rpx 0;
}

.product-category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-image-wrapper {
  width: 100%;
  height: 160rpx;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.category-image {
  width: 100%;
  height: 100%;
}

.category-name {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
}

.view-all-btn {
  text-align: center;
  margin-top: 20rpx;
  padding: 16rpx 0;
  color: #1E88E5;
  font-size: 26rpx;
  background-color: #f0f7ff;
  border-radius: 8rpx;
}

.view-all-btn:active {
  background-color: #e3f2fd;
}

.contact-info {
  margin: 20rpx 0;
}

.contact-item {
  display: flex;
  align-items: center;
  margin: 10rpx 0;
  padding: 10rpx 0;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #666666;
}

.contact-card {
  text-align: center;
}
