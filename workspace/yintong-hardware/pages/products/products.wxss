/* pages/products/products.wxss - 产品中心样式 */
.filter-bar {
  background-color: #ffffff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 20rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #1E88E5;
  color: #ffffff;
}

.product-list {
  padding-bottom: 20rpx;
}

.product-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-image {
  width: 100%;
  height: 400rpx;
  background-color: #f0f0f0;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-category {
  font-size: 24rpx;
  color: #1E88E5;
  background-color: #e3f2fd;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.contact-tip {
  text-align: center;
  margin-top: 20rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.btn-small {
  padding: 16rpx 40rpx;
  font-size: 26rpx;
}
