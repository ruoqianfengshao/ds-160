/* pages/contact/contact.wxss - 联系我们样式 */
.company-info {
  padding: 0;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-content {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.contact-value {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.arrow-icon {
  font-size: 40rpx;
  color: #cccccc;
  margin-left: 10rpx;
}

.action-buttons-card {
  padding: 30rpx 24rpx;
}

.action-buttons-large {
  display: flex;
  gap: 20rpx;
}

.action-btn-large {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  border: none;
}

.action-btn-large::after {
  border: none;
}

.btn-call {
  background: linear-gradient(135deg, #1E88E5 0%, #1565C0 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 229, 0.3);
}

.btn-nav {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.btn-large-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.btn-large-text {
  font-size: 28rpx;
  font-weight: 500;
}

.map-card {
  padding: 0;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 500rpx;
}

.map-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 16rpx;
  background-color: #fafafa;
}
