/* pages/cases/cases.wxss - 案例展示样式 */
.cases-list {
  padding-bottom: 20rpx;
}

.case-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.case-cover {
  width: 100%;
  height: 400rpx;
  background-color: #f0f0f0;
}

.case-info {
  padding: 20rpx;
}

.case-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.case-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.case-industry {
  display: flex;
  align-items: center;
}

.industry-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.industry-text {
  font-size: 24rpx;
  color: #1E88E5;
  background-color: #e3f2fd;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #cccccc;
}

.contact-tip {
  text-align: center;
  margin-top: 20rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.btn-small {
  padding: 16rpx 40rpx;
  font-size: 26rpx;
}
