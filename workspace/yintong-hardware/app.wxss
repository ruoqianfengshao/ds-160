/* app.wxss - 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333333;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #1E88E5;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-primary:active {
  background-color: #1565C0;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标题样式 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1E88E5;
  margin-bottom: 16rpx;
  text-align: center;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 30rpx;
}
