/* pages/contact/contact.wxss */
.contact-card {
  margin-bottom: 20rpx;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.contact-item:active {
  background: #e6f7ff;
  transform: scale(0.98);
}

.contact-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.contact-icon-wrapper.phone {
  background: linear-gradient(135deg, #ffe58f 0%, #ffd666 100%);
}

.contact-icon-wrapper.email {
  background: linear-gradient(135deg, #bae7ff 0%, #91d5ff 100%);
}

.contact-icon-wrapper.address {
  background: linear-gradient(135deg, #ffc069 0%, #ffa940 100%);
}

.contact-icon-wrapper.map {
  background: linear-gradient(135deg, #95de64 0%, #73d13d 100%);
}

.contact-icon {
  font-size: 40rpx;
}

.contact-info {
  flex: 1;
  min-width: 0;
}

.contact-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-action {
  font-size: 26rpx;
  color: #1890ff;
  padding: 12rpx 24rpx;
  background: #e6f7ff;
  border-radius: 30rpx;
  margin-left: 16rpx;
}

.work-time {
  line-height: 2;
}

.time-item {
  margin-bottom: 16rpx;
}

.time-label {
  font-size: 28rpx;
  color: #666;
}

.time-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.time-tip {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fffbe6;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fa8c16;
}

.message-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  width: 100%;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  min-height: 200rpx;
  box-sizing: border-box;
}

.btn-submit {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

.social-links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.social-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.social-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.social-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}
