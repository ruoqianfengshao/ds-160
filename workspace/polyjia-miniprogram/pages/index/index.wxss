/* pages/index/index.wxss */
.banner {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
  color: #fff;
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.company-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 28rpx;
  opacity: 0.9;
}

.intro-card {
  text-align: center;
}

.intro-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 30rpx;
  text-align: left;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.business-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  transition: all 0.3s;
}

.business-item:active {
  background: #e6f7ff;
  transform: scale(0.98);
}

.business-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.business-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.business-desc {
  font-size: 24rpx;
  color: #999;
}

.news-list {
  margin-bottom: 20rpx;
}

.news-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.news-item:last-child {
  border-bottom: none;
}

.news-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.news-date {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.btn-more {
  background: transparent;
  color: #1890ff;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

.contact-info {
  margin-bottom: 30rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #333;
}
